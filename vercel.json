{
  "routes": [
    {
      "src": "/share/exam/(?<slug>[^/]+)/?",
      "dest": "/api/share?slug=$slug"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
