{
  "rewrites": [
    {
      "source": "/exam/:slug",
      "destination": "/api/share?slug=:slug"
    },
    {
      "source": "/share/exam/:slug",
      "destination": "/api/share?slug=:slug"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
