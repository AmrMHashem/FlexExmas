{
  "rewrites": [
    {
      "source": "/exam/:slug",
      "destination": "/api/share?slug=:slug"
    },
    {
      "source": "/share/exam/:slug",
      "destination": "/api/share?slug=:slug"
    },
    {
      "source": "/((?!api|exam|share).*)",
      "destination": "/index.html"
    }
  ]
}
