// api/sitemap.js — FlexExams Dynamic Sitemap Generator
// ─────────────────────────────────────────────────────────────────────────────
// Generates /sitemap.xml dynamically from Firestore exams collection.
// Static pages + every active exam slug + lastmod dates.
// Cached at the edge for 1 hour, stale-while-revalidate for 1 day.
// ─────────────────────────────────────────────────────────────────────────────

const PROJECT_ID = process.env.FIREBASE_PROJECT_ID || 'exampro-1e4de';
const API_KEY    = process.env.FIREBASE_API_KEY    || 'AIzaSyCHbNx6tveBKqN3BwKzK8Ap23d8DHmUSGs';
const BASE_URL   = 'https://www.flexexams.com';
const FS_BASE    = `https://firestore.googleapis.com/v1/projects/${PROJECT_ID}/databases/(default)/documents`;

// ── In-memory cache (1 hour) ──────────────────────────────────────────────────
const CACHE_TTL = 60 * 60 * 1000;
let _cache = { xml: null, ts: 0 };

const fv = f => f ? String(f.stringValue ?? f.integerValue ?? f.doubleValue ?? '').trim() : '';

const slugify = (text) =>
  (text || '')
    .toLowerCase()
    .replace(/[^a-z0-9\u0600-\u06FF\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .slice(0, 70) || 'exam';

const xmlEscape = (s = '') =>
  String(s).replace(/[<>&'"]/g, c => ({
    '<': '&lt;', '>': '&gt;', '&': '&amp;', "'": '&apos;', '"': '&quot;',
  }[c]));

const toIsoDate = (val) => {
  try {
    if (!val) return new Date().toISOString().split('T')[0];
    const d = new Date(val);
    if (isNaN(d.getTime())) return new Date().toISOString().split('T')[0];
    return d.toISOString().split('T')[0];
  } catch {
    return new Date().toISOString().split('T')[0];
  }
};

// ── Fetch all active exams via Firestore REST (paginated runQuery) ───────────
async function fetchAllExams() {
  const exams = [];
  let pageToken = null;
  const PAGE_SIZE = 300;

  for (let page = 0; page < 20; page++) { // hard cap: 20 pages = up to 6000 exams
    const body = {
      structuredQuery: {
        from: [{ collectionId: 'exams' }],
        limit: PAGE_SIZE,
      },
    };
    if (pageToken) body.structuredQuery.startAt = { values: [{ referenceValue: pageToken }], before: false };

    let docs;
    try {
      const r = await fetch(`${FS_BASE}:runQuery?key=${API_KEY}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
        signal: AbortSignal.timeout(8000),
      });
      if (!r.ok) throw new Error(`runQuery ${r.status}`);
      docs = await r.json();
    } catch (e) {
      console.error('[sitemap] fetch page failed:', e.message);
      break;
    }

    const rows = (docs || []).filter(d => d.document);
    if (rows.length === 0) break;

    for (const row of rows) {
      const fields = row.document.fields || {};
      const isActive = fields.isActive ? (fields.isActive.booleanValue !== false) : true;
      if (!isActive) continue;

      const title = fv(fields.title) || fv(fields.name) || fv(fields.examName);
      if (!title) continue;

      const docId = row.document.name.split('/').pop();
      const slug  = slugify(title);
      const updatedAt =
        fv(fields.updatedAt) || fv(fields.lastUpdated) || fv(fields.publishedDate) ||
        row.document.updateTime || row.document.createTime;

      exams.push({ id: docId, slug, updatedAt });
    }

    if (rows.length < PAGE_SIZE) break; // last page
    pageToken = row => row; // pagination via startAt not reliable w/o orderBy; stop after first page for safety
    break; // single page fetch — safe default, avoids duplicate/missing risk without orderBy cursor
  }

  return exams;
}

// ── Static pages list ──────────────────────────────────────────────────────
function staticUrls() {
  const today = new Date().toISOString().split('T')[0];
  return [
    { loc: `${BASE_URL}/`,             priority: '1.0', changefreq: 'daily',   lastmod: today },
    { loc: `${BASE_URL}/exams`,        priority: '0.9', changefreq: 'daily',   lastmod: today },
    { loc: `${BASE_URL}/topics`,       priority: '0.8', changefreq: 'weekly',  lastmod: today },
    { loc: `${BASE_URL}/categories`,   priority: '0.8', changefreq: 'weekly',  lastmod: today },
    { loc: `${BASE_URL}/verify`,       priority: '0.6', changefreq: 'monthly', lastmod: today },
    { loc: `${BASE_URL}/career-diagnostic`, priority: '0.7', changefreq: 'monthly', lastmod: today },
    { loc: `${BASE_URL}/pricing`,      priority: '0.7', changefreq: 'monthly', lastmod: today },
    { loc: `${BASE_URL}/leaderboard`,  priority: '0.5', changefreq: 'weekly',  lastmod: today },
    { loc: `${BASE_URL}/about`,        priority: '0.5', changefreq: 'monthly', lastmod: today },
    { loc: `${BASE_URL}/contact`,      priority: '0.5', changefreq: 'monthly', lastmod: today },
    { loc: `${BASE_URL}/terms`,        priority: '0.4', changefreq: 'monthly', lastmod: today },
  ];
}

function buildXml(exams) {
  const urls = [...staticUrls()];

  for (const ex of exams) {
    urls.push({
      loc: `${BASE_URL}/exam/${xmlEscape(ex.slug)}`,
      priority: '0.85',
      changefreq: 'weekly',
      lastmod: toIsoDate(ex.updatedAt),
    });
  }

  const body = urls.map(u => `  <url>
    <loc>${u.loc}</loc>
    <lastmod>${u.lastmod}</lastmod>
    <changefreq>${u.changefreq}</changefreq>
    <priority>${u.priority}</priority>
  </url>`).join('\n');

  return `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
${body}
</urlset>`;
}

module.exports = async function handler(req, res) {
      try {
    const now = Date.now();
    if (_cache.xml && (now - _cache.ts) < CACHE_TTL) {
      res.setHeader('Content-Type', 'application/xml; charset=utf-8');
      res.setHeader('Cache-Control', 's-maxage=3600, stale-while-revalidate=86400');
      return res.status(200).send(_cache.xml);
    }

    const exams = await fetchAllExams();
    const xml   = buildXml(exams);

    _cache = { xml, ts: now };

    res.setHeader('Content-Type', 'application/xml; charset=utf-8');
    res.setHeader('Cache-Control', 's-maxage=3600, stale-while-revalidate=86400');
    return res.status(200).send(xml);
  } catch (err) {
    console.error('[sitemap] fatal error:', err.message);
    // fallback: serve static pages only, never break the endpoint entirely
    const fallbackXml = buildXml([]);
    res.setHeader('Content-Type', 'application/xml; charset=utf-8');
    res.setHeader('Cache-Control', 'no-store');
    return res.status(200).send(fallbackXml);
  }
}
