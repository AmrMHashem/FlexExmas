rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(userId) { return isAuth() && request.auth.uid == userId; }

    function isAdmin() {
      return isAuth() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ✅ NEW: limited "manager" access — granted from Admin → Users → Manage Access.
    // accessRoles is an array on the user doc, e.g. ["exams","vendors","topics","import","questions"]
    function isManager(section) {
      return isAuth() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accessRoles is list &&
             section in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accessRoles;
    }

    // ✅ FIX v4: تم تعديل الحقول المحمية لتشمل "purchases" فقط (وليس "purchasedExams")
    function notChangingProtectedFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'role', 'createdAt', 'uid',
        'subscription',
        'points', 'purchases', 'totalScore', 'leaderboardRank', 'referralRewards',
        'isAdmin', 'billing', 'paymentStatus',
        'accessRoles' // ✅ NEW: only admins can grant/revoke section access
      ]);
    }

    // ======================= المستخدمون =======================
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isAdmin() || isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && notChangingProtectedFields());
      allow delete: if isAdmin();

      match /examProgress/{examId} {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }

    // ======================= الامتحانات =======================
    match /exams/{examId} {
      allow read, list: if true;
      allow create, update, delete: if isAdmin() || isManager('exams') || isManager('import');
      match /questions/{questionId} {
        allow read, list: if true;
        allow create, update, delete: if isAdmin() || isManager('exams') || isManager('questions') || isManager('import');
      }
    }

    // ======================= الأسئلة =======================
    match /questions/{questionId} {
      allow read, list: if true;
      allow create, update, delete: if isAdmin() || isManager('questions') || isManager('import');
    }

    // ======================= إحصائيات الامتحانات =======================
    match /examStats/{examId} {
      allow read, list: if true;
      allow create, update, delete: if isAdmin() || isManager('exams');
    }

    // ======================= النتائج =======================
    match /results/{resultId} {
      allow read: if isAdmin() || (isAuth() && request.auth.uid == resource.data.userId);
      allow list: if isAdmin() || (isAuth() && request.query.filters.size() > 0);
      allow create: if isAdmin() || (isAuth()
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.keys().hasAll(['userId', 'examId', 'score'])
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ======================= التقارير =======================
    match /reports/{reportId} {
      allow create: if isAdmin() || (isAuth() && request.resource.data.userId == request.auth.uid);
      allow read, update, delete: if isAdmin();
    }

    // ======================= الموردون =======================
    match /vendors/{vendorId} {
      allow read, list: if true;
      allow create, update, delete: if isAdmin() || isManager('vendors');
    }

    // ======================= المواضيع =======================
    match /topics/{topicId} {
      allow read, list: if true;
      allow create, update, delete: if isAdmin() || isManager('topics');
    }

    // ======================= الشهادات =======================
    match /certificates/{certId} {
      allow read: if true;
      allow create: if isAdmin() || (isAuth() && request.auth.uid != null && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ======================= الإعدادات =======================
    match /settings/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ======================= المعاملات المالية =======================
    match /transactions/{txId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || isAuth();
      allow create: if isAdmin() || (isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'type', 'amount', 'status'])
        && request.resource.data.amount is number
        && request.resource.data.amount >= 0
        && (request.resource.data.status == 'completed' || request.resource.data.status == 'pending')
      );
      allow update: if isAdmin() || (isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt'])
        && request.resource.data.status == 'cancelled'
      );
      allow delete: if isAdmin();
    }

    // ======================= لوحة المتصدرين =======================
    match /leaderboard/{userId} {
      allow read, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // ======================= الإحالات =======================
    match /referrals/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create, update, delete: if isAdmin();
    }

    // ======================= الإشعارات =======================
    match /notifications/{notificationId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || (isAuth() && request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (isAuth() 
        && resource.data.userId == request.auth.uid 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']));
      allow delete: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
    }

    // ======================= رسائل الاتصال (CONTACT MESSAGES) =======================
    match /contactMessages/{messageId} {
      allow create: if request.resource.data.keys().hasOnly([
        'name', 'email', 'subject', 'type', 'message', 'senderType', 
        'userId', 'userName', 'status', 'adminReply', 'repliedAt', 'createdAt'
      ])
      && request.resource.data.name is string
      && request.resource.data.name.size() > 0
      && request.resource.data.name.size() <= 100
      && request.resource.data.email is string
      && request.resource.data.email.size() <= 100
      && request.resource.data.email.matches('^[^@\\s]+@([^@\\s]+\\.)+[^@\\s]+$')
      && request.resource.data.subject is string
      && request.resource.data.subject.size() > 0
      && request.resource.data.subject.size() <= 200
      && request.resource.data.message is string
      && request.resource.data.message.size() > 0
      && request.resource.data.message.size() <= 5000
      && request.resource.data.status == 'unread'
      && (request.resource.data.senderType == 'member' || request.resource.data.senderType == 'visitor');

      allow read, list: if isAdmin();
      allow update: if isAdmin() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'adminReply', 'repliedAt'])
      );
      allow delete: if isAdmin();
    }

    // ======================= طلبات الاسترداد =======================
    match /refund_requests/{refundId} {
      allow create: if isAdmin() || (isAuth() && request.resource.data.userId == request.auth.uid);
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ======================= مدفوعات InstaPay =======================
    match /instapay_payments/{paymentId} {
      allow create: if isAdmin() || (isAuth() && request.resource.data.userId == request.auth.uid);
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ======================= الاشتراكات =======================
    match /subscriptions/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isAdmin() || (isOwner(userId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.keys().hasAll(['userId', 'planId', 'status', 'startDate', 'endDate'])
      );
      allow update: if isAdmin() || (isOwner(userId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt'])
        && (request.resource.data.status == 'cancelled' || request.resource.data.status == 'inactive')
      );
      allow delete: if isAdmin();
    }

    // ======================= الكوبونات =======================
    match /coupons/{couponId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // ======================= التحليلات =======================
    match /analytics/{docId} {
      allow read, create, update, delete: if isAdmin();
    }

    // ======================= سجلات الأدمن =======================
    match /admin_logs/{logId} {
      allow read, create, update, delete: if isAdmin();
    }

    // ======================= رفض أي شيء آخر =======================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
